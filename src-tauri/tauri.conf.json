{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RenForge",
  "version": "1.1.0",
  "identifier": "com.foulnike.renforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows":[
      {
        "title": "RenForge",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
        "assetProtocol": {
          "enable": true,
          "scope": ["**"]
        }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon":[
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin":[
      "bin/unrpa",
      "bin/unrpyc"
    ]
  }
}